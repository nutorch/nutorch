---
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: "website" | "article";
}

const { title, description, canonical, ogType = "website" } = Astro.props;
const site = Astro.site ?? Astro.url;
const ogImage = new URL("/images/og-nutorch.png", site);
const canonicalUrl = canonical ? new URL(canonical, site) : undefined;
const ogUrl = canonicalUrl ?? new URL(Astro.url.pathname, site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/images/nutorch-2d-192.png" type="image/png" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:site_name" content="NuTorch" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      // Theme init, before first paint. Two layers: the SETTING
      // (system|light|dark, localStorage) and the RESOLVED mode
      // (light|dark, data-theme — what all CSS keys on). A pre-set
      // data-theme attribute short-circuits everything (test harness /
      // SSR escape hatch). In system mode the OS preference is tracked
      // LIVE via the matchMedia change listener.
      (() => {
        const root = document.documentElement;
        if (root.dataset.theme) return;
        const media = matchMedia("(prefers-color-scheme: dark)");
        let setting = null;
        try {
          setting = localStorage.getItem("theme");
        } catch {}
        if (setting !== "light" && setting !== "dark") setting = "system";
        root.dataset.themeSetting = setting;
        root.dataset.theme = setting === "system"
          ? (media.matches ? "dark" : "light")
          : setting;
        media.addEventListener("change", () => {
          if (root.dataset.themeSetting === "system") {
            root.dataset.theme = media.matches ? "dark" : "light";
          }
        });
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-background text-foreground antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
